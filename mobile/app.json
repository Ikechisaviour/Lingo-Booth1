{
  "expo": {
    "name": "Lingo Booth",
    "slug": "lingo-booth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "lingobooth",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#faf7f2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lingobooth.app"
    },
    "android": {
      "package": "com.lingobooth.app",
      "adaptiveIcon": {
        "backgroundColor": "#faf7f2",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "61ea2a51-1b2d-44fd-af79-7ddf10ea3ad5"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
