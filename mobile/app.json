{
  "expo": {
    "name": "Lingo Booth",
    "slug": "lingo-booth",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "lingobooth",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#faf7f2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lingobooth.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Lingo Booth uses the microphone for hands-free speaking practice.",
        "NSSpeechRecognitionUsageDescription": "Lingo Booth uses speech recognition to turn your spoken practice into text.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.lingobooth.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#faf7f2"
      },
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "61ea2a51-1b2d-44fd-af79-7ddf10ea3ad5"
      },
      "googleWebClientId": "185911237323-s79tga5o3b53bsnri35sibmn1srg0en5.apps.googleusercontent.com"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Lingo Booth to use the microphone for speaking practice.",
          "speechRecognitionPermission": "Allow Lingo Booth to use speech recognition for hands-free practice.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#58cc02",
          "defaultChannel": "lingo_booth_notifications"
        }
      ],
      "./plugins/withPictureInPicture",
      "./plugins/withAndroidFixes",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "newArchEnabled": true,
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "expo-localization",
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.185911237323-1emudeqdbf3kkuvvjm19evvqeap8ul56"
        }
      ]
    ]
  }
}
