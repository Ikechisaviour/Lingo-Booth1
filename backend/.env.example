MONGODB_URI=mongodb://localhost:27017/korean-learning
JWT_SECRET=your_jwt_secret_key_here
PORT=5000
NODE_ENV=development

# Production: comma-separated list of allowed frontend origins
# FRONTEND_ORIGINS=https://lingobooth.com,https://www.lingobooth.com,https://lingo-booth1.vercel.app
FRONTEND_ORIGIN=http://localhost:3000

# Email verification (Resend — https://resend.com)
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
FRONTEND_URL=http://localhost:3001

# Certificate PDF downloads render the public certificate page with headless Chrome/Edge.
# Set CERTIFICATE_RENDER_URL to the web app origin users should see in certificates.
# Set CHROME_PATH only if Chrome/Edge is not discoverable on the server PATH.
CERTIFICATE_RENDER_URL=http://localhost:3000
# CHROME_PATH=/usr/bin/google-chrome

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Admin-only speaking demo AI conversation (DeepSeek via OpenAI-compatible base https://api.deepseek.com)
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# DEEPSEEK_CONVERSATION_MODEL=deepseek-v4-flash
# AI_PROVIDER_TIMEOUT_MS=12000
# ENABLE_LOCAL_DEMO_BYPASS=true

# AI daily-token quota gate. Default (unset or any value other than "false") = limits are
# DISABLED for everyone — the AI conversation never returns a 429 quota error. Set to
# "false" to re-enable the per-tier daily token limits in backend/utils/subscription.js.
# AI_TOKEN_LIMITS_DISABLED=false

# Billing and subscriptions (Stripe web checkout)
# Create products/prices in Stripe, then paste the price ids here.
# Leave blank during development; checkout endpoints will report setup is required.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PLUS_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_ULTRA_MONTHLY=
STRIPE_PRICE_ULTRA_ANNUAL=

# Mobile store product ids. Receipt validation credentials are still required
# before mobile purchases can be activated automatically.
IOS_PRODUCT_PLUS_MONTHLY=
IOS_PRODUCT_PLUS_ANNUAL=
IOS_PRODUCT_PRO_MONTHLY=
IOS_PRODUCT_PRO_ANNUAL=
IOS_PRODUCT_ULTRA_MONTHLY=
IOS_PRODUCT_ULTRA_ANNUAL=
ANDROID_PRODUCT_PLUS_MONTHLY=
ANDROID_PRODUCT_PLUS_ANNUAL=
ANDROID_PRODUCT_PRO_MONTHLY=
ANDROID_PRODUCT_PRO_ANNUAL=
ANDROID_PRODUCT_ULTRA_MONTHLY=
ANDROID_PRODUCT_ULTRA_ANNUAL=
IOS_SHARED_SECRET=
ANDROID_PACKAGE_NAME=
