{
  "name": "korean-learning-app",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://localhost:5001",
  "dependencies": {
    "@react-oauth/google": "^0.13.4",
    "axios": "^1.4.0",
    "chart.js": "^3.9.1",
    "i18next": "^23.16.8",
    "react": "^18.2.0",
    "react-chartjs-2": "^4.3.1",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.0",
    "react-i18next": "^14.1.3",
    "react-icons": "^4.8.0",
    "react-router-dom": "^6.10.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "audit:guardrails": "node scripts/auditGuardrails.js && node scripts/auditLocaleKeys.js && node scripts/auditLocalePlaceholders.js && node scripts/auditLanguagePolicy.js && node scripts/auditClassLanguagePolicy.js && node scripts/auditDynamicLocalizedCopy.js && node scripts/auditI18nLeaks.js",
    "audit:i18n": "node scripts/auditLocaleKeys.js",
    "audit:i18n-leaks": "node scripts/auditI18nLeaks.js",
    "i18n:harvest": "node scripts/harvestI18nDefaults.js",
    "i18n:fill-locales": "node ../backend/scripts/translateLocaleKeys.js",
    "audit:language-policy": "node scripts/auditLanguagePolicy.js && node scripts/auditClassLanguagePolicy.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "react-scripts": "^5.0.1"
  }
}
